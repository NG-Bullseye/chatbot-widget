# --- Django ---
DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=*
DATABASE_URL=postgres://chatbot:chatbot@localhost:5432/chatbot

# Origin(s) of the website that embeds the widget (comma-separated).
ALLOWED_ORIGINS=http://localhost:8000,https://www.example.com

# --- Chat LLM (OpenAI-compatible endpoint) ---
# DSGVO: Chat-Eingaben sind Freitext und potenziell personenbezogen. Der
# Provider ist Auftragsverarbeiter -- EU-Verarbeitung oder DPF-Zertifizierung
# + abgeschlossener DPA/AVV noetig, und "kein Training auf API-Daten".
# Geeignet: Mistral (EU), OpenAI mit DPA (DPF), Azure OpenAI (EU-Region),
# Anthropic mit DPA. NICHT geeignet: DeepSeek (Verarbeitung in China,
# unsicheres Drittland ohne Angemessenheitsbeschluss).
LLM_API_KEY=...
LLM_MODEL=mistral-small-latest
LLM_BASE_URL=https://api.mistral.ai/v1
LLM_TEMPERATURE=0.3

# --- Embeddings (separate provider; DeepSeek has none) ---
EMBEDDING_API_KEY=sk-openai-...
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_BASE_URL=https://api.openai.com/v1
# Migration-bound: the vector column dimension is frozen at makemigrations time.
# Changing this later needs `makemigrations knowledge` + `migrate` AND a full
# re-index. The app refuses to start (system check knowledge.E001) on mismatch.
EMBEDDING_DIM=1536

# --- Datenaufbewahrung (DSGVO Art. 5 Abs. 1 lit. e) ---
# Chat-Verlaeufe aelter als so viele Tage loescht `manage.py purge_conversations`
# (taeglich per Cron ausfuehren). Gleiche Frist in Langfuse als Data Retention
# konfigurieren.
CONVERSATION_RETENTION_DAYS=90

# --- System prompt (customer-specific) ---
# Either inline...
SYSTEM_PROMPT=
# ...or a file path (takes precedence if set and exists):
SYSTEM_PROMPT_FILE=

# --- Langfuse (self-hosted via docker-compose) ---
# Traces enthalten die kompletten Chat-Inhalte (personenbezogen). Bei Langfuse
# Cloud die EU-Region nutzen (https://cloud.langfuse.com, NICHT us.cloud...),
# DPA abschliessen und Data Retention auf CONVERSATION_RETENTION_DAYS setzen.
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=http://localhost:3000
