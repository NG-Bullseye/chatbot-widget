# --- Django ---
DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=*
DATABASE_URL=postgres://chatbot:chatbot@localhost:5432/chatbot

# Origin(s) of the website that embeds the widget (comma-separated).
ALLOWED_ORIGINS=http://localhost:8000,https://www.example.com

# --- Chat LLM (default: DeepSeek V3, OpenAI-compatible) ---
LLM_API_KEY=sk-deepseek-...
LLM_MODEL=deepseek-chat
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_TEMPERATURE=0.3

# --- Embeddings (separate provider; DeepSeek has none) ---
EMBEDDING_API_KEY=sk-openai-...
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_BASE_URL=https://api.openai.com/v1
# Migration-bound: the vector column dimension is frozen at makemigrations time.
# Changing this later needs `makemigrations knowledge` + `migrate` AND a full
# re-index. The app refuses to start (system check knowledge.E001) on mismatch.
EMBEDDING_DIM=1536

# --- System prompt (customer-specific) ---
# Either inline...
SYSTEM_PROMPT=
# ...or a file path (takes precedence if set and exists):
SYSTEM_PROMPT_FILE=

# --- Langfuse (self-hosted via docker-compose) ---
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=http://localhost:3000
