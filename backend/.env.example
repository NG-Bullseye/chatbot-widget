# --- Django ---
DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=*
DATABASE_URL=postgres://chatbot:chatbot@localhost:5432/chatbot

# --- Django (Produktion: alle drei zwingend setzen) ---
# DJANGO_DEBUG steht per Default auf false. Niemals auf true in Produktion:
# Djangos Fehlerseiten rendern bei jedem 500er die komplette Umgebung
# inklusive aller API-Keys in den Browser.
DJANGO_DEBUG=true
# Ohne Default in Produktion. Erzeugen mit:
#   python -c "from django.core.management.utils import get_random_secret_key as k; print(k())"
DJANGO_SECRET_KEY=
# Kommagetrennt, die Domain(s) unter denen das Backend erreichbar ist.
DJANGO_ALLOWED_HOSTS=chatbot.example.com
# Kommagetrennt, mit Schema -- fuer CSRF hinter dem Railway-Proxy.
DJANGO_CSRF_TRUSTED_ORIGINS=https://chatbot.example.com

# Origin(s) of the website that embeds the widget (comma-separated).
ALLOWED_ORIGINS=http://localhost:8000,https://www.example.com

# --- Chat LLM (OpenAI-compatible endpoint) ---
# Pflichtfelder ohne Default -- die App startet nicht, wenn eines fehlt.
# Absicht: Chat-Eingaben sind Freitext und potenziell personenbezogen, also
# muss das Ziel dieser Daten eine bewusste Deploy-Entscheidung sein und darf
# nicht aus einem Code-Default fallen.
#
# Modell und Anbieter sind zwei verschiedene Dinge: dasselbe Modell bei einem
# anderen Anbieter bedeutet einen anderen Rechtsraum. Massgeblich ist, wohin
# LLM_BASE_URL zeigt, nicht wie das Modell heisst.
#
# Gewaehlt: Mistral. Frankreich, Verarbeitung ausschliesslich in der EU, also
# kein Drittlandtransfer fuer den Chat-Inhalt. DPA vorhanden, kein Training
# auf API-Daten bei den bezahlten APIs, 30 Tage Retention beim Anbieter.
LLM_API_KEY=...
LLM_MODEL=mistral-small-latest
LLM_BASE_URL=https://api.mistral.ai/v1
LLM_TEMPERATURE=0.3

# --- Embeddings (separate provider; DeepSeek has none) ---
EMBEDDING_API_KEY=sk-openai-...
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_BASE_URL=https://api.openai.com/v1
# Migration-bound: the vector column dimension is frozen at makemigrations time.
# Changing this later needs `makemigrations knowledge` + `migrate` AND a full
# re-index. The app refuses to start (system check knowledge.E001) on mismatch.
EMBEDDING_DIM=1536

# --- Datenaufbewahrung (DSGVO Art. 5 Abs. 1 lit. e) ---
# Chat-Verlaeufe aelter als so viele Tage loescht `manage.py purge_conversations`
# (taeglich per Cron ausfuehren). Gleiche Frist in Langfuse als Data Retention
# konfigurieren.
CONVERSATION_RETENTION_DAYS=90

# --- System prompt (customer-specific) ---
# Either inline...
SYSTEM_PROMPT=
# ...or a file path (takes precedence if set and exists):
SYSTEM_PROMPT_FILE=

# --- Langfuse (self-hosted via docker-compose) ---
# Traces enthalten die kompletten Chat-Inhalte (personenbezogen). Bei Langfuse
# Cloud die EU-Region nutzen (https://cloud.langfuse.com, NICHT us.cloud...),
# DPA abschliessen und Data Retention auf CONVERSATION_RETENTION_DAYS setzen.
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=http://localhost:3000
